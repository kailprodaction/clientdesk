# Скопируйте в .env и заполните. Все переменные опциональны для локального запуска.

# Секрет для сессий/CSRF (в проде обязателен)
SECRET_KEY=dev-change-me

# Claude API. Без ключа AI-отчёты работают в офлайн-фолбэке (детерминированный шаблон).
ANTHROPIC_API_KEY=
CLAUDE_MODEL=claude-sonnet-5

# Путь к БД и папке загрузок (по умолчанию рядом с приложением)
# DATABASE_URL=sqlite:///clientdesk.db
# UPLOAD_DIR=uploads
